  (text "BAT: 2S 550mAh LiHV (7.4V) XT30 | FC: F405 Mini 20x20 ICM42688 DPS310 | ESC: BLS 35A 4in1 DShot600" (at 25.00 280.00 0) (effects (font (size 1.27 1.27))))
  (text "Motor: Specter 1804 3500KV 13.3g 12x12 M2 1.5mm shaft | Prop: GEMFAN 3052 3in 22.8mm clearance" (at 25.00 277.00 0) (effects (font (size 1.27 1.27))))
  (text "VTX: Zeus 350mW 16x16->20x20 SMA Foxeer Lollipop rear | CAM: Caddx Ant 14x14->19x19 adapter" (at 25.00 274.00 0) (effects (font (size 1.27 1.27))))
  (text "RX: SuperD ELRS 22x14 1.1g Dual SX1280 CRSF@420k | ANT1 vert L ANT2 horiz top >=40mm apart" (at 25.00 271.00 0) (effects (font (size 1.27 1.27))))
  (text "GPS: M100-5883 M10 QMC5883L (opt) | Stack: ESC(4.5)+NUT(2)+FC(6.5)+NUT(2)=15mm | 25mm standoffs" (at 25.00 268.00 0) (effects (font (size 1.27 1.27))))
  (text "=== WIRING ===" (at 25.00 262.00 0) (effects (font (size 2.54 2.54))))
  (text "22AWG: VBAT GND 5V | 26AWG: UART ESC signals | 28AWG: I2C | JST-SH 1.0mm CAM-VTX | JST-GH GPS" (at 25.00 258.00 0) (effects (font (size 1.27 1.27))))
  (text "Heat shrink all solder joints | Continuity check before power | ShortSaver MANDATORY" (at 25.00 255.00 0) (effects (font (size 1.27 1.27))))
