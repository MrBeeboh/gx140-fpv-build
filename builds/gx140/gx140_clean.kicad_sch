  (text "GX140 3in ANALOG FPV — ELECTRICAL SCHEMATIC" (at 40.64 285.00 0) (effects (font (size 3.81 3.81))))
  (text "=== POWER ===" (at 25.40 278.00 0) (effects (font (size 2.54 2.54))))
  (text "Battery: 2S 550mAh LiHV (7.4V) XT30 -> FC VBAT -> Internal 5V/3A BEC" (at 25.40 273.00 0) (effects (font (size 1.524 1.524))))
  (text "5V RAIL: FC BEC -> VTX(Zeus350) + CAM(CaddxAnt) + RX(SuperD) + GPS(M100-opt)" (at 25.40 268.00 0) (effects (font (size 1.27 1.27))))
  (text "=== SIGNAL ROUTING ===" (at 25.40 262.00 0) (effects (font (size 2.54 2.54))))
  (text "UART4(TX4): FC -> VTX SmartAudio RX | SmartAudio 2.1 | 115200 baud" (at 25.40 257.00 0) (effects (font (size 1.27 1.27))))
  (text "UART5(TX5/RX5): FC <=> RX CRSF | ELRS V3 | 420000 baud" (at 25.40 253.00 0) (effects (font (size 1.27 1.27))))
  (text "UART3(TX3/RX3): FC <=> GPS (optional) | UBLOX | 57600 baud | M100-5883" (at 25.40 249.00 0) (effects (font (size 1.27 1.27))))
  (text "=== MOTOR OUTPUTS (DShot600) ===" (at 25.40 243.00 0) (effects (font (size 2.54 2.54))))
  (text "M1: FC M1 -> ESC S1 -> Motor FL (CCW) | M2: FC M2 -> ESC S2 -> Motor FR (CW)" (at 25.40 238.00 0) (effects (font (size 1.27 1.27))))
  (text "M3: FC M3 -> ESC S3 -> Motor RL (CCW) | M4: FC M4 -> ESC S4 -> Motor RR (CW)" (at 25.40 234.00 0) (effects (font (size 1.27 1.27))))
  (text "Motors: HGLRC Specter 1804 3500KV | 13.3g | 12x12 M2 | 22.68x13.2mm | 1.5mm shaft" (at 25.40 230.00 0) (effects (font (size 1.27 1.27))))
  (text "=== CAMERA and VTX ===" (at 25.40 224.00 0) (effects (font (size 2.54 2.54))))
  (text "CAM: Caddx Ant 1200TVL 14x14->19x19 | VID -> VTX CAM_IN (JST-SH 1.0mm 4-pin)" (at 25.40 219.00 0) (effects (font (size 1.27 1.27))))
  (text "VTX: HGLRC Zeus 350mW 16x16->20x20 | SMA -> Foxeer Lollipop RHCP (rear, 50mm)" (at 25.40 215.00 0) (effects (font (size 1.27 1.27))))
  (text "=== RECEIVER ===" (at 25.40 209.00 0) (effects (font (size 2.54 2.54))))
  (text "RX: BETAFPV SuperD ELRS Diversity | 22x14mm 1.1g | Dual SX1280 | CRSF at 420000" (at 25.40 204.00 0) (effects (font (size 1.27 1.27))))
  (text "ANT1: Vertical left standoff (60mm active) | ANT2: Horizontal top plate rear (60mm)" (at 25.40 200.00 0) (effects (font (size 1.27 1.27))))
  (text "Separation: VTX->RX1 >=25mm | RX1->RX2 >=40mm | All >10mm from carbon/props" (at 25.40 196.00 0) (effects (font (size 1.016 1.016))))
  (text "=== COMPONENT SPECS ===" (at 25.40 190.00 0) (effects (font (size 2.54 2.54))))
  (text "FC: SpeedyBee F405 Mini 20x20 | ICM42688 | DPS310 | 25x25x6.5mm | 4 UARTs" (at 25.40 185.00 0) (effects (font (size 1.27 1.27))))
  (text "ESC: BLS 35A 4in1 20x20 | 3-6S | DShot600 | 25x25x4.5mm | Bidirectional ON" (at 25.40 181.00 0) (effects (font (size 1.27 1.27))))
  (text "BAT: 2S 550mAh LiHV (7.6V 75C) XT30 | 30x18x15mm | 4-5min flight | LVC 3.5V/cell" (at 25.40 177.00 0) (effects (font (size 1.27 1.27))))
  (text "=== MECHANICAL ===" (at 25.40 171.00 0) (effects (font (size 2.54 2.54))))
  (text "FRAME: GX140 140mm 4mm carbon | Twin 20x20 tower | 8x M3x25mm alu standoffs" (at 25.40 166.00 0) (effects (font (size 1.27 1.27))))
  (text "STACK: ESC(4.5)+NUT(2)+FC(6.5)+NUT(2)=15mm | Standoff: 25mm | Clearance: 10mm" (at 25.40 162.00 0) (effects (font (size 1.27 1.27))))
  (text "PROPS: GEMFAN 3052 3in tri-blade | 5mm hub+1.5mm adapter | 22.8mm clearance" (at 25.40 158.00 0) (effects (font (size 1.27 1.27))))
  (text "AUW: ~190g (under 250g limit) | CG: <1mm offset | ALL DIRECT FIT — NO MODS" (at 25.40 154.00 0) (effects (font (size 1.27 1.27))))
  (text "=== WIRING ===" (at 25.40 148.00 0) (effects (font (size 2.54 2.54))))
  (text "22AWG: VBAT, GND, 5V rail | 26AWG: UART, ESC signals | 28AWG: I2C, sensors" (at 25.40 143.00 0) (effects (font (size 1.27 1.27))))
  (text "JST-SH 1.0mm: CAM to VTX | JST-GH 1.25mm: GPS, I2C | Heat shrink all joints" (at 25.40 139.00 0) (effects (font (size 1.27 1.27))))
  (text "=== SAFETY ===" (at 25.40 133.00 0) (effects (font (size 2.54 2.54))))
  (text "ShortSaver MANDATORY before first power | Props OFF for motor test" (at 25.40 128.00 0) (effects (font (size 1.27 1.27))))
  (text "Continuity check all power rails before plugging battery" (at 25.40 124.00 0) (effects (font (size 1.27 1.27))))
  (text "Verify motor direction in Betaflight Configurator (Motors tab)" (at 25.40 120.00 0) (effects (font (size 1.27 1.27))))
  (text "GROK — FPV Drone Engineering | 2025-12-12 | Sheet 1/1 | All dimensions verified" (at 340.00 15.00 0) (effects (font (size 1.27 1.27))))



