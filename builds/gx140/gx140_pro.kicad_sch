  (text "=== BUILD SPECIFICATIONS ===" (at 25.00 120.00 0) (effects (font (size 2.54 2.54))))
  (text "Frame: GX140 140mm 4mm carbon | Twin 20x20 tower | 8x M3x25mm alu standoffs | ~45g bare" (at 25.00 116.00 0) (effects (font (size 1.27 1.27))))
  (text "FC: SpeedyBee F405 Mini 20x20 ICM42688 DPS310 | 25x25x6.5mm | 4 UARTs | USB-C" (at 25.00 113.00 0) (effects (font (size 1.27 1.27))))
  (text "ESC: BLS 35A 4in1 20x20 DShot600 Bidirectional ON | 25x25x4.5mm | 3-6S | 5V/3A BEC" (at 25.00 110.00 0) (effects (font (size 1.27 1.27))))
  (text "Motor: HGLRC Specter 1804 3500KV | 13.3g | 12x12mm M2 | 1.5mm shaft | 22.68x13.2mm" (at 25.00 107.00 0) (effects (font (size 1.27 1.27))))
  (text "Prop: GEMFAN 3052 3in tri-blade | 5mm hub+1.5mm adapter | 22.8mm tip clearance" (at 25.00 104.00 0) (effects (font (size 1.27 1.27))))
  (text "VTX: Zeus 350mW 16x16->20x20 | PIT/25/100/200/350mW | SmartAudio | SMA | Foxeer Lollipop" (at 25.00 101.00 0) (effects (font (size 1.27 1.27))))
  (text "CAM: Caddx Ant 1200TVL 14x14 | 19x19 adapter included | JST-SH 1.0mm 4-pin | 1.8mm F1.6" (at 25.00 98.00 0) (effects (font (size 1.27 1.27))))
  (text "RX: SuperD ELRS 22x14mm 1.1g | Dual SX1280 | CRSF@420k | ANT1 vert L ANT2 horiz top" (at 25.00 95.00 0) (effects (font (size 1.27 1.27))))
  (text "GPS: Matek M10Q-5883 UBLOX M10 (optional) | QMC5883L | JST-GH 1.25mm 6-pin | 5Hz default" (at 25.00 92.00 0) (effects (font (size 1.27 1.27))))
  (text "BAT: 2S 550mAh LiHV (7.6V 75C) XT30 | 30x18x15mm | 4-5min flight | LVC 3.5V/cell" (at 25.00 89.00 0) (effects (font (size 1.27 1.27))))
  (text "=== WIRING ===" (at 25.00 82.00 0) (effects (font (size 2.54 2.54))))
  (text "22AWG: VBAT, GND, 5V rail | 26AWG: UART signals, ESC PWM | 28AWG: I2C sensors" (at 25.00 78.00 0) (effects (font (size 1.27 1.27))))
  (text "JST-SH 1.0mm: CAM to VTX | JST-GH 1.25mm: GPS, I2C | XT30: Battery | Heat shrink all" (at 25.00 75.00 0) (effects (font (size 1.27 1.27))))
  (text "=== SAFETY ===" (at 25.00 69.00 0) (effects (font (size 2.54 2.54))))
  (text "ShortSaver MANDATORY before first power | Props OFF for motor direction test" (at 25.00 65.00 0) (effects (font (size 1.27 1.27))))
  (text "Continuity check all rails before battery | Verify in Betaflight Configurator | CG <1mm" (at 25.00 62.00 0) (effects (font (size 1.27 1.27))))
  (text "AUW: ~190g (under 250g limit) | ALL COMPONENTS DIRECT FIT — ZERO MODIFICATIONS" (at 25.00 59.00 0) (effects (font (size 1.27 1.27))))
